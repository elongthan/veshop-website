# Copy this file to .env.local and fill in the values from your Supabase project
# Settings > API in your Supabase dashboard

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Required for Phase 3 (adding/removing admin users, username login).
# Supabase dashboard → Settings → API Keys → "Secret keys" → the sb_secret_... value.
# NEVER put this in a NEXT_PUBLIC_ variable or send it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — without these, the Contact Us form falls back to opening the
# visitor's own email app instead of sending directly. Sign up free at
# resend.com to enable real server-side sending.
RESEND_API_KEY=
CONTACT_TO_EMAIL=sales@veshop.com.sg
